{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raigulus.github.io/schemas/lore-entry.schema.json",
  "title": "Raigulus Lore Entry",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "slug",
    "section",
    "summary",
    "canon_status",
    "connection_status",
    "spoiler_level",
    "claims",
    "sections",
    "verification"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "type": {"type": "string"},
    "title": {"type": "string", "minLength": 1},
    "slug": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "section": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "summary": {"type": "string", "minLength": 1},
    "canon_status": {"type": "string"},
    "connection_status": {
      "enum": [
        "confirmed-influence",
        "explicit-reference",
        "documented-parallel",
        "thematic-similarity",
        "community-theory",
        "disputed"
      ]
    },
    "spoiler_level": {"enum": ["none", "minor", "major"]},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text", "assessment", "source_ids"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "text": {"type": "string", "minLength": 1},
          "assessment": {"type": "string", "minLength": 1},
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"},
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "sections": {"type": "array", "minItems": 1},
    "comparisons": {"type": "array"},
    "relations": {"type": "array"},
    "verification": {
      "type": "object",
      "required": ["status", "last_reviewed", "human_reviewed"],
      "properties": {
        "status": {"enum": ["draft", "source-reviewed", "human-reviewed", "published", "superseded"]},
        "last_reviewed": {"type": "string", "format": "date"},
        "human_reviewed": {"type": "boolean"},
        "notes": {"type": "string"}
      }
    }
  },
  "additionalProperties": false
}
