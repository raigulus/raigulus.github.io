{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raigulus.github.io/schemas/lore-entry.schema.json",
  "title": "Raigulus Lore Entry",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "franchise",
    "continuity",
    "type",
    "title",
    "slug",
    "section",
    "summary",
    "canon_status",
    "connection_status",
    "spoiler_level",
    "claims",
    "sections",
    "verification"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "franchise": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "continuity": {
      "enum": [
        "division-game-universe",
        "division-transmedia",
        "tom-clancy-work",
        "real-world",
        "editorial-comparison",
        "unknown"
      ]
    },
    "type": {
      "enum": [
        "person",
        "faction",
        "organization",
        "location",
        "event",
        "mission",
        "concept",
        "technology",
        "disease",
        "collectible",
        "work",
        "real-world-event",
        "government-directive"
      ]
    },
    "title": {"type": "string", "minLength": 1},
    "slug": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "section": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "summary": {"type": "string", "minLength": 1},
    "canon_status": {
      "enum": [
        "game-canon",
        "official-transmedia",
        "alternate-continuity",
        "real-world",
        "real-world-with-fictional-extension",
        "editorial-comparison",
        "unknown",
        "disputed"
      ]
    },
    "connection_status": {
      "enum": [
        "not-applicable",
        "confirmed-influence",
        "explicit-reference",
        "documented-parallel",
        "thematic-similarity",
        "community-theory",
        "disputed"
      ]
    },
    "spoiler_level": {"enum": ["none", "minor", "major"]},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text", "assessment", "source_ids"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "text": {"type": "string", "minLength": 1},
        "assessment": {
          "enum": [
            "confirmed",
            "confirmed-influence",
            "confirmed-fictional-extension",
            "editorial-distinction",
            "documented-parallel",
            "thematic-similarity",
            "community-theory",
            "disputed",
            "unknown"
          ]
        },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"},
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "sections": {"type": "array", "minItems": 1},
    "comparisons": {"type": "array"},
    "timeline": {
      "type": "object",
      "required": ["sequence", "label", "precision", "source_ids"],
      "properties": {
        "sequence": {"type": "integer", "minimum": 0},
        "label": {"type": "string", "minLength": 1},
        "precision": {
          "enum": ["exact-date", "month", "year", "relative", "sequence-only"]
        },
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_id", "relationship"],
        "properties": {
          "target_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "relationship": {
            "enum": [
              "member-of",
              "former-member-of",
              "leader-of",
              "former-leader-of",
              "allied-with",
              "opposed-to",
              "held-by",
              "appears-in",
              "mentioned-in",
              "located-at",
              "involves",
              "occurs-during",
              "precedes",
              "follows",
              "causes",
              "creator-of",
              "created-by",
              "contributes-to",
              "assimilated-by",
              "contradicts",
              "confirmed-influence",
              "documented-parallel",
              "adaptation-of",
              "co-foundational-influence"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "verification": {
      "type": "object",
      "required": ["status", "last_reviewed", "human_reviewed"],
      "properties": {
        "status": {"enum": ["draft", "source-reviewed", "human-reviewed", "published", "superseded"]},
        "last_reviewed": {"type": "string", "format": "date"},
        "human_reviewed": {"type": "boolean"},
        "reviewed_by": {"type": "string"},
        "notes": {"type": "string"}
      }
    }
  },
  "additionalProperties": false
}
