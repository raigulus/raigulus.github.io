{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raigulus.github.io/schemas/lore-inventory.schema.json",
  "title": "Raigulus Lore Coverage Inventory",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "title",
    "game",
    "inventory_status",
    "last_audited",
    "categories"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "title": {"type": "string", "minLength": 1},
    "game": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "inventory_status": {
      "enum": ["inventory-pending", "in-progress", "blocked", "reconciled"]
    },
    "last_audited": {"type": "string", "format": "date"},
    "notes": {"type": "string"},
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "expected_count",
          "captured_count",
          "source_reviewed_count",
          "human_reviewed_count",
          "published_count",
          "status",
          "notes"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "label": {"type": "string", "minLength": 1},
          "expected_count": {"type": ["integer", "null"], "minimum": 0},
          "captured_count": {"type": "integer", "minimum": 0},
          "source_reviewed_count": {"type": "integer", "minimum": 0},
          "human_reviewed_count": {"type": "integer", "minimum": 0},
          "published_count": {"type": "integer", "minimum": 0},
          "status": {
            "enum": ["inventory-pending", "in-progress", "blocked", "reconciled"]
          },
          "notes": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
